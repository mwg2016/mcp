# Shopify MCP Server Environment Variables
# Copy this file to .env and replace with your actual Shopify store details

# Your Shopify store domain (e.g., mystore.myshopify.com)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Your Shopify access token (Admin API access token)
SHOPIFY_ACCESS_TOKEN=your-access-token-here